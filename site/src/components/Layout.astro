---
const {
  title = 'BizSys 現場改善システム企画/開発/保守',
  description = '',
  ogType = 'website',
  ogImage = '/images/hero-right.png',
} = Astro.props;
const siteUrl = 'https://bizsys.jp';

// canonicalは常に「末尾スラッシュあり」に正規化する（2026-07-08）。
// 内部リンクやリダイレクトがスラッシュなしURLを指しても、canonicalを一本化することで
// /blog/foo と /blog/foo/ の二重インデックス（SEO評価の分散）を防ぐ。
const path = Astro.url.pathname;
const normalizedPath = path.endsWith('/') ? path : `${path}/`;
const canonicalUrl = `${siteUrl}${normalizedPath}`;
---
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content="BizSys" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="ja_JP" />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    {/* 本番ビルド時のみGA4を発火させる（localhost等の開発アクセスを計測に混入させないため） */}
    {import.meta.env.PROD && (
      <>
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-04S9SZW07N"></script>
        <script>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-04S9SZW07N');
        </script>
      </>
    )}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js" defer></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700;800;900&display=swap" rel="stylesheet">
    <style is:global>
      /* ====================================================
         Reset & Base
         ==================================================== */
      *, *::before, *::after { box-sizing: border-box; }
      html { overflow-x: hidden; }
      body {
        margin: 0;
        font-family: 'Noto Sans JP', 'Hiragino Sans', system-ui, sans-serif;
        color: #10233f;
        background: #fff;
        line-height: 1.7;
        overflow-x: hidden;
      }
      a { text-decoration: none; color: inherit; }

      /* ====================================================
         Container
         ==================================================== */
      .container {
        width: min(1180px, calc(100% - 48px));
        margin: 0 auto;
      }

      /* ====================================================
         Header
         ==================================================== */
      .header {
        background: #fff;
        border-bottom: 1px solid #e4ecf5;
        position: sticky;
        top: 0;
        z-index: 10;
      }
      .header-inner {
        height: 78px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .logo {
        display: flex;
        align-items: baseline;
        gap: 10px;
      }
      .logo-main {
        font-size: 34px;
        font-weight: 800;
        color: #073b78;
      }
      .logo-sub {
        font-size: 14px;
        font-weight: 700;
        color: #555;
      }
      .nav {
        display: flex;
        align-items: center;
        gap: 28px;
        font-weight: 700;
      }
      .nav a {
        padding: 26px 0;
        font-size: 15px;
        color: #10233f;
      }
      .nav a:hover { color: #005bac; }
      .nav a.active {
        color: #005bac;
        border-bottom: 4px solid #005bac;
        padding-bottom: 22px;
      }
      .nav-cta {
        background: #073b78;
        color: #fff !important;
        padding: 13px 18px !important;
        border-radius: 6px;
        font-size: 14px;
      }
      .nav-cta:hover { background: #0a4f9f !important; color: #fff; }

      /* ---- ハンバーガーボタン ---- */
      .nav-toggle {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
      }
      .nav-toggle span {
        display: block;
        width: 26px;
        height: 2px;
        background: #073b78;
        border-radius: 2px;
        transition: transform 0.2s, opacity 0.2s;
      }
      .nav-toggle[aria-expanded="true"] span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      .nav-toggle[aria-expanded="true"] span:nth-child(2) {
        opacity: 0;
      }
      .nav-toggle[aria-expanded="true"] span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      /* ---- モバイルメニュー ---- */
      .mobile-menu {
        display: none;
        background: #fff;
        border-bottom: 1px solid #e4ecf5;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
      }
      .mobile-menu.open {
        display: block;
        position: fixed;
        top: 78px;
        left: 0;
        right: 0;
        z-index: 9;
        max-height: calc(100vh - 78px);
        overflow-y: auto;
      }
      body.menu-open { overflow: hidden; }
      .mobile-menu a {
        display: block;
        padding: 14px 24px;
        font-size: 15px;
        font-weight: 700;
        color: #10233f;
        border-bottom: 1px solid #f0f4f8;
      }
      .mobile-menu a:hover { background: #f4f9fe; color: #005bac; }
      .mobile-menu a.active { color: #005bac; }
      .mobile-menu .nav-cta {
        display: block;
        margin: 16px 24px;
        text-align: center;
        border-radius: 6px;
        padding: 13px 18px !important;
      }

      /* ====================================================
         Footer
         ==================================================== */
      .site-footer {
        background: #fff;
        border-top: 1px solid #d9e7f5;
        margin-top: 0;
      }
      .site-footer__inner {
        width: min(calc(100% - 48px), 1180px);
        margin: 0 auto;
        padding: 22px 0 20px;
        display: grid;
        grid-template-columns: 160px 1fr auto;
        align-items: center;
        gap: 36px;
      }
      .site-footer__logo {
        display: inline-block;
        color: #004b91;
        font-size: 28px;
        font-weight: 850;
        line-height: 1;
        text-decoration: none;
        letter-spacing: -0.02em;
      }
      .site-footer__nav { display: flex; align-items: center; min-width: 0; }
      .site-footer__nav-list {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px 18px;
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .site-footer__nav-list a {
        color: #0f2f55;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: color 0.2s;
      }
      .site-footer__nav-list a:hover { color: #004b91; }
      .site-footer__company { text-align: left; white-space: nowrap; }
      .site-footer__company-name {
        margin: 0 0 6px;
        color: #0f2f55;
        font-size: 15px;
        font-weight: 800;
      }
      .site-footer__company-link {
        color: #5b6f86;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
      }
      .site-footer__company-link:hover { color: #004b91; }
      .site-footer__bottom {
        width: min(calc(100% - 48px), 1180px);
        margin: 0 auto;
        padding: 14px 0 22px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        border-top: 1px solid #d9e7f5;
      }
      .site-footer__copyright {
        margin: 0;
        color: #5b6f86;
        font-size: 13px;
        font-weight: 600;
      }
      .site-footer__privacy {
        color: #0f2f55;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
      }
      .site-footer__privacy:hover { color: #004b91; }

      /* ====================================================
         Buttons
         ==================================================== */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 16px 34px;
        font-weight: 800;
        font-size: 16px;
        box-shadow: 0 6px 14px rgba(0,0,0,.12);
        transition: opacity 0.15s, transform 0.15s;
        cursor: pointer;
      }
      .btn:hover { opacity: 0.88; transform: translateY(-2px); }
      .btn.primary { background: #ff7a00; color: #fff; }
      .btn.secondary { background: #fff; color: #073b78; border: 2px solid #073b78; }
      .btn.large { font-size: 20px; min-width: 260px; }

      /* ====================================================
         共通 CTA ポイント
         ==================================================== */
      .cta-points {
        display: flex;
        flex-direction: row;
        gap: 20px;
        margin-top: 20px;
        font-weight: 700;
        font-size: 14px;
        color: rgba(255,255,255,0.8);
      }

      /* ====================================================
         Section
         ==================================================== */
      .section { padding: 56px 0; }
      .section.light { background: #f4f9fe; }

      h2 {
        font-size: 28px;
        font-weight: 800;
        margin: 0 0 24px;
        color: #073b78;
      }

      /* ====================================================
         Cards（共通）
         ==================================================== */
      .card,
      .panel,
      .case-card,
      .price-card {
        background: #fff;
        border: 1px solid #dce8f4;
        border-radius: 10px;
        padding: 22px;
        box-shadow: 0 6px 18px rgba(18, 65, 110, .05);
      }
      .card { font-size: 30px; }
      .card h3,
      .case-card h3 {
        font-size: 17px;
        color: #073b78;
        margin: 8px 0 4px;
        font-weight: 800;
      }
      .card p,
      .case-card p { font-size: 14px; margin: 0; color: #445; }

      /* ====================================================
         フォーム
         ==================================================== */
      .form-group { margin-bottom: 24px; }
      .form-group label {
        display: block;
        font-size: 0.9rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 8px;
      }
      .form-group input,
      .form-group textarea {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid #cdd6e8;
        border-radius: 8px;
        font-size: 1rem;
        font-family: inherit;
        color: #111;
        background: #fff;
        transition: border-color 0.15s;
        box-sizing: border-box;
      }
      .form-group input:focus,
      .form-group textarea:focus { outline: none; border-color: #005bac; }
      .form-group textarea { resize: vertical; min-height: 120px; }
      .form-submit { margin-top: 8px; }

      /* ====================================================
         ブログ
         ==================================================== */
      .blog-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 20px; }
      .blog-item {
        background: #fff;
        border: 1px solid #dce8f4;
        border-radius: 10px;
        padding: 24px;
        box-shadow: 0 6px 18px rgba(18, 65, 110, .05);
      }
      .blog-item > a { color: #073b78; text-decoration: none; font-size: 1.1rem; font-weight: 700; }
      .blog-item > a:hover { text-decoration: underline; }
      .blog-item small { color: #888; font-size: 0.85rem; }
      .blog-item p { margin: 8px 0 0; color: #555; font-size: 0.95rem; line-height: 1.7; }
      .blog-article { background: #fff; border-radius: 10px; padding: 40px; border: 1px solid #dce8f4; }
      .blog-article h1 { font-size: 1.8rem; font-weight: 900; color: #073b78; margin: 0 0 16px; }
      .blog-article .blog-meta { color: #888; font-size: 0.88rem; margin: 0 0 24px; }
      .blog-article .blog-tags { color: #005bac; font-size: 0.88rem; margin: 0 0 32px; }
      .blog-article .prose { line-height: 1.9; color: #333; }
      .blog-article .prose h2 { font-size: 1.3rem; font-weight: 700; margin: 2em 0 0.8em; color: #073b78; }
      .blog-article .prose h3 { font-size: 1.1rem; font-weight: 700; margin: 1.6em 0 0.6em; color: #005bac; }
      .blog-article .prose p { margin: 0 0 1.2em; }
      .blog-article .prose ul, .blog-article .prose ol { padding-left: 1.5em; margin: 0 0 1.2em; line-height: 2; }

      /* ---- TOC ---- */
      .toc { background: #f4f9fe; border-radius: 10px; border: 1px solid #dce8f4; padding: 24px 28px; margin: 0 0 40px; }
      .toc-title { font-size: 0.9rem; font-weight: 700; color: #073b78; letter-spacing: 0.08em; margin: 0 0 12px; text-transform: uppercase; }
      .toc-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
      .toc-list a { color: #005bac; text-decoration: none; font-size: 0.92rem; line-height: 1.5; display: flex; align-items: flex-start; gap: 8px; }
      .toc-list a::before { content: '–'; color: #073b78; flex-shrink: 0; margin-top: 1px; }
      .toc-list a:hover { text-decoration: underline; }

      /* ---- タグリンク ---- */
      .blog-tag-link { color: #073b78; text-decoration: none; font-size: 0.82rem; font-weight: 700; background: #d9ecfb; border-radius: 4px; padding: 2px 8px; }
      .blog-tag-link:hover { background: #b8ddf5; text-decoration: none; }
      .tag-page-title { font-size: 1.4rem; font-weight: 700; color: #073b78; margin: 0 0 32px; }
      .tag-highlight { color: #005bac; background: #d9ecfb; border-radius: 6px; padding: 2px 10px; }
      .no-posts { text-align: center; padding: 48px 0; color: #666; }
      .btn-back { display: inline-block; margin-top: 16px; color: #005bac; text-decoration: none; font-weight: 700; }
      .btn-back:hover { text-decoration: underline; }

      /* ====================================================
         レスポンシブ
         ==================================================== */
      @media (max-width: 900px) {
        .nav { display: none; }
        .nav-toggle { display: flex; }
        .header .container { width: 100%; padding: 0 8px 0 12px; }
        h2 { font-size: 22px; }
        .blog-article { padding: 24px; }
        .site-footer__inner {
          grid-template-columns: 1fr;
          align-items: start;
          gap: 18px;
          padding: 24px 0 18px;
        }
        .site-footer__company { white-space: normal; }
        .site-footer__bottom { width: min(calc(100% - 48px), 1180px); }
      }
      @media (max-width: 560px) {
        .container { width: min(100% - 28px, 1180px); }
        .site-footer__inner { width: min(calc(100% - 32px), 1180px); }
        .site-footer__nav-list {
          display: grid;
          grid-template-columns: repeat(2, minmax(0, 1fr));
          width: 100%;
          gap: 10px 16px;
        }
        .site-footer__bottom {
          width: min(calc(100% - 32px), 1180px);
          flex-direction: column-reverse;
          align-items: flex-start;
          padding-bottom: 20px;
        }
      }
    </style>
  </head>
  <body>
    <header class="header">
      <div class="container header-inner">
        <a class="logo" href="/">
          <span class="logo-main">BizSys</span>
          <span class="logo-sub">現場改善システムの開発/保守</span>
        </a>
        <nav class="nav">
          <a href="/" class:list={[{ active: path === '/' }]}>ホーム</a>
          <a href="/services" class:list={[{ active: path.startsWith('/services') }]}>サービス</a>
          <a href="/cases" class:list={[{ active: path.startsWith('/cases') }]}>導入事例</a>
          <a href="/demo" class:list={[{ active: path.startsWith('/demo') }]}>操作デモ</a>
          <a href="/pricing" class:list={[{ active: path.startsWith('/pricing') }]}>料金</a>
          <a href="/blog" class:list={[{ active: path.startsWith('/blog') }]}>ブログ</a>
          <a href="/contact" class="nav-cta">
            <svg xmlns="http://www.w3.org/2000/svg" style="margin:0 5px 0 0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            無料相談する
          </a>
        </nav>
        <button class="nav-toggle" aria-expanded="false" aria-label="メニューを開く">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>
    <div class="mobile-menu" id="mobile-menu">
      <a href="/" class:list={[{ active: path === '/' }]}>ホーム</a>
      <a href="/services" class:list={[{ active: path.startsWith('/services') }]}>サービス</a>
      <a href="/cases" class:list={[{ active: path.startsWith('/cases') }]}>導入事例</a>
      <a href="/demo" class:list={[{ active: path.startsWith('/demo') }]}>操作デモ</a>
      <a href="/pricing" class:list={[{ active: path.startsWith('/pricing') }]}>料金</a>
      <a href="/blog" class:list={[{ active: path.startsWith('/blog') }]}>ブログ</a>
      <a href="/contact" class="nav-cta">
         <svg xmlns="http://www.w3.org/2000/svg" style="margin:0 5px 0 0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
         無料相談する
      </a>
    </div>
    <script>
      const toggle = document.querySelector('.nav-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle.addEventListener('click', () => {
        const open = menu.classList.toggle('open');
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        document.body.classList.toggle('menu-open', open);
      });
      // メニュー内リンクをタップしたら閉じる
      menu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          menu.classList.remove('open');
          toggle.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('menu-open');
        });
      });
    </script>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__brand">
          <a class="site-footer__logo" href="/">BizSys</a>
        </div>
        <nav class="site-footer__nav" aria-label="フッターメニュー">
          <ul class="site-footer__nav-list">
            <li><a href="/">ホーム</a></li>
            <li><a href="/services">サービス</a></li>
            <li><a href="/cases">導入事例</a></li>
            <li><a href="/demo">操作デモ</a></li>
            <li><a href="/pricing">料金</a></li>
            <li><a href="/blog">ブログ</a></li>
          </ul>
        </nav>
        <div class="site-footer__company">
          <p class="site-footer__company-name">運営会社：株式会社 SOB</p>
          <a class="site-footer__company-link" href="https://s-o-b.jp/" target="_blank" rel="noopener noreferrer">会社HP：https://s-o-b.jp/</a>
        </div>
      </div>
      <div class="site-footer__bottom">
        <p class="site-footer__copyright">© 2026 BizSys</p>
        <a class="site-footer__privacy" href="/privacy">プライバシーポリシー</a>
      </div>
    </footer>
  </body>
</html>
