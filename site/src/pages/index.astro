---
import Layout from '../components/Layout.astro';
---

<Layout title="そのExcel管理、そろそろ限界じゃないですか？ | ビズシス">

  <style>
    /* ---- ヒーロー（ページ固有） ---- */
    .hero {
      background: linear-gradient(135deg, #061e3f 0%, #0a4f9f 60%, #1a6fd4 100%);
      border-radius: 0;
      margin: 0 -32px;
    }
    .hero-top {
      padding: 56px 32px 32px;
      max-width: 1080px;
      margin: 0 auto;
    }
    .hero-eyebrow {
      color: rgba(255, 255, 255, 0.9);
      font-weight: 700;
      letter-spacing: 0.1em;
      margin: 0 0 20px;
      font-size: 0.85rem;
      border: 1px solid rgba(255, 255, 255, 0.4);
      padding: 4px 12px;
      border-radius: 999px;
      display: inline-block;
    }
    .hero h1 {
      font-size: 3.5rem;
      line-height: 1.15;
      margin: 0;
      color: #fff;
      font-weight: 900;
    }
    .hero-bottom {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: center;
      padding: 32px 32px 64px;
      max-width: 1080px;
      margin: 0 auto;
    }
    .hero-lead {
      font-size: 1.1rem;
      line-height: 1.9;
      margin: 0 0 24px;
      color: rgba(255, 255, 255, 0.85);
    }
    .hero .btn-primary {
      background: #ffffff;
      color: #0a4f9f;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
    }
    .hero .btn-primary:hover { background: #e8f0fb; transform: translateY(-2px); }
    .hero .btn-secondary {
      background: transparent;
      color: #ffffff;
      border-color: rgba(255, 255, 255, 0.6);
    }
    .hero .btn-secondary:hover { background: rgba(255, 255, 255, 0.1); transform: translateY(-2px); }
    .hero-card {
      background: #ffffff;
      border-radius: 24px;
      padding: 32px;
      box-shadow: 0 20px 48px rgba(0, 0, 0, 0.25);
    }
    .hero-card h2 { color: #111; margin: 0 0 16px; font-size: 1.15rem; font-weight: 700; }
    .hero-card ul { color: #444; padding-left: 20px; line-height: 2.1; margin: 0; }

    /* ---- 実績数字 ---- */
    .stats-section { background: #ffffff; }
    .stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .stat {
      background: #fff;
      padding: 28px 20px;
      border-radius: 16px;
      box-shadow: 0 10px 30px rgba(10, 79, 159, 0.08);
      text-align: center;
    }
    .stat strong {
      display: block;
      font-size: 2.2rem;
      color: #0a4f9f;
      font-weight: 900;
      margin-bottom: 6px;
    }
    .stat span { font-size: 0.85rem; color: #666; }

    /* ---- チーム紹介 ---- */
    .team-section { background: #ffffff; }
    .team-body { line-height: 1.85; color: #444; margin: 0 0 28px; }
    .team-list { padding-left: 20px; line-height: 2.2; color: #444; margin: 0; }

    /* ---- サービス ---- */
    .services-section { background: #f5f8ff; }
    .pricing-box {
      background: #eef3fb;
      border-left: 4px solid #0a4f9f;
      border-radius: 0 12px 12px 0;
      padding: 24px 28px;
      margin-top: 36px;
    }
    .pricing-box h3 { margin: 0 0 10px; font-size: 0.9rem; font-weight: 700; color: #0a4f9f; text-transform: uppercase; letter-spacing: 0.08em; }
    .pricing-box ul { padding-left: 20px; line-height: 2; margin: 0 0 8px; color: #333; }
    .pricing-box p { margin: 0; font-size: 0.88rem; color: #777; }

    /* ---- 開発事例 ---- */
    .cases-section { background: #ffffff; }
    .cases-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .case-card {
      background: #fff;
      border-radius: 16px;
      padding: 22px;
      box-shadow: 0 10px 28px rgba(18, 38, 63, 0.07);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      cursor: default;
    }
    .case-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 48px rgba(10, 79, 159, 0.15);
    }
    .case-card h3 { margin: 0 0 8px; font-size: 0.95rem; font-weight: 700; color: #0a4f9f; }
    .case-card p { margin: 0; font-size: 0.88rem; line-height: 1.65; color: #555; }

    /* ---- ツール ---- */
    .tools-section { background: #f5f8ff; }
    .tools-list { padding-left: 20px; line-height: 2.1; margin: 0 0 16px; color: #444; }
    .tools-desc { line-height: 1.85; color: #444; margin: 0 0 24px; }

    /* ---- FAQ ---- */
    .faq-section { background: #ffffff; }
    .faq-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .faq-card {
      background: #fff;
      border-radius: 20px;
      padding: 28px;
      box-shadow: 0 14px 36px rgba(18, 38, 63, 0.08);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      cursor: default;
    }
    .faq-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 48px rgba(10, 79, 159, 0.15);
    }
    .faq-card.faq-full { grid-column: span 3; }
    .faq-card h3 { margin: 0 0 12px; font-size: 0.95rem; color: #0a4f9f; font-weight: 700; }
    .faq-card p { margin: 0; line-height: 1.75; font-size: 0.92rem; color: #444; }

    /* ---- 最下部CTA ---- */
    .cta-section { background: #f7f8fb; }
    .cta-block {
      background: #0a4f9f;
      color: #fff;
      border-radius: 24px;
      padding: 56px 40px;
      text-align: center;
    }
    .cta-block h2 { margin: 0 0 16px; font-size: 1.6rem; font-weight: 700; }
    .cta-block p { margin: 0; line-height: 1.85; opacity: 0.9; }
    .cta-block .btn-primary {
      background: #ffffff;
      color: #0a4f9f;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
    }
    .cta-block .btn-primary:hover { background: #e8f0fb; transform: translateY(-2px); }
    .cta-block .btn-secondary {
      background: transparent;
      color: #fff;
      border-color: rgba(255, 255, 255, 0.6);
    }
    .cta-block .btn-secondary:hover { background: rgba(255, 255, 255, 0.1); }

    /* ---- レスポンシブ（ページ固有分） ---- */
    @media (max-width: 900px) {
      .hero { margin: 0 -32px; }
      .hero h1 { font-size: 2.2rem; }
      .hero-bottom { grid-template-columns: 1fr; padding: 24px 32px 48px; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .cases-grid { grid-template-columns: repeat(2, 1fr); }
      .faq-grid { grid-template-columns: 1fr; }
      .faq-card.faq-full { grid-column: span 1; }
      .cta-block { padding: 40px 24px; }
    }
    @media (max-width: 480px) {
      .hero { margin: 0 -16px; }
      .hero-top { padding: 40px 16px 24px; }
      .hero-bottom { padding: 16px 16px 40px; }
      .hero h1 { font-size: 1.9rem; }
      .stats { grid-template-columns: 1fr; }
      .cases-grid { grid-template-columns: 1fr; }
    }
  </style>

  <!-- ヒーロー（3ゾーン構成） -->
  <section id="hero" class="hero">
    <div class="hero-top">
      <p class="hero-eyebrow">現場のExcel管理に、終止符を。</p>
      <h1>そのExcel管理、そろそろ限界じゃないですか？</h1>
    </div>
    <div class="hero-bottom">
      <div>
        <p class="hero-lead">
          ビズシスは、業務システム開発・保守に特化した少数精鋭チームです。<br />
          Excelの限界を解消し、現場業務を自動化して、運用負担を軽減します。
        </p>
        <div class="cta-group">
          <a class="btn-primary" href="/contact">まずは相談する</a>
          <a class="btn-secondary" href="/cases">導入事例を見る</a>
        </div>
      </div>
      <div class="hero-card">
        <h2>Excel管理は見えないコストを生む</h2>
        <ul>
          <li>入力ミスによるデータ不整合</li>
          <li>バージョン管理の混乱</li>
          <li>集計作業の二度手間</li>
          <li>担当者依存による属人化</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- 実績数字（6項目） -->
  <section id="stats" class="section stats-section">
    <div class="section-inner">
      <div class="stats">
        <div class="stat"><strong>14年</strong><span>エンジニア歴</span></div>
        <div class="stat"><strong>★5.0</strong><span>ココナラ評価</span></div>
        <div class="stat"><strong>550件以上</strong><span>販売実績</span></div>
        <div class="stat"><strong>25社以上</strong><span>業務システム導入</span></div>
        <div class="stat"><strong>89社以上</strong><span>楽天・Yahoo出品ツール</span></div>
        <div class="stat"><strong>10社以上</strong><span>保守継続中</span></div>
      </div>
    </div>
  </section>

  <!-- チーム紹介文 -->
  <section id="team" class="section team-section">
    <div class="section-inner">
      <h2 class="section-title">少数精鋭チームが業務システム化をワンストップで支援</h2>
      <p class="team-body">
        ビズシスは、システム開発・保守を専門とする少数精鋭のチームです。<br />
        エンジニア歴14年・ココナラ評価★5.0・販売実績550件以上の実績を持ち、<br />
        要件整理〜設計〜実装〜保守まで一貫して対応します。
      </p>
      <ul class="team-list">
        <li>Excel管理の限界を理解した現場寄りの設計</li>
        <li>追加費用を抑えるシンプル設計</li>
        <li>相談しやすい少数精鋭体制</li>
      </ul>
    </div>
  </section>

  <!-- サービス内容 -->
  <section id="services" class="section services-section">
    <div class="section-inner">
      <h2 class="section-title">Excel管理から脱却する提供サービス</h2>
      <div class="card-grid">
        <div class="card">
          <svg class="card-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#0a4f9f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="4" y="6" width="32" height="22" rx="3"/>
            <path d="M14 34h12M20 28v6"/>
            <path d="M13 17l4 4 8-8"/>
          </svg>
          <h3>業務システム開発</h3>
          <p>Excel・スプレッドシート管理から脱却したい中小企業向け。案件管理・在庫管理・売上管理などの現場システムを構築します。</p>
        </div>
        <div class="card">
          <svg class="card-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#0a4f9f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 4.5l-1.2 4.4a10.5 10.5 0 00-3.8 2.2L7.6 9.7 4 15.8l3.2 3.3a10.5 10.5 0 000 4.3L4 26.5l3.6 6.2 4.4-1.4a10.5 10.5 0 003.8 2.2L17 37.5h6l1.2-4.4a10.5 10.5 0 003.8-2.2l4.4 1.4 3.6-6.2-3.2-3.3a10.5 10.5 0 000-4.3l3.2-3.3-3.6-6.2-4.4 1.4a10.5 10.5 0 00-3.8-2.2L23 4.5h-6z"/>
            <circle cx="20" cy="21" r="5"/>
          </svg>
          <h3>ツール・Webシステム開発</h3>
          <p>楽天・Yahoo出品ツールや在庫管理ツールなど、現場で使える仕組みを作ります。既存ツールとの連携やデータ自動化にも対応します。</p>
        </div>
        <div class="card">
          <svg class="card-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="#0a4f9f" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 4l14 5v10c0 9.5-7 15-14 17C13 34 6 28.5 6 19V9l14-5z"/>
            <path d="M14 20l4 4 8-8"/>
          </svg>
          <h3>保守・運用サポート</h3>
          <p>システムを導入して終わりではなく、継続的な改善と安定運用をサポートします。月1万円〜の保守プランで安心して任せられる体制を提供します。</p>
        </div>
      </div>
      <div class="pricing-box">
        <h3>料金の目安</h3>
        <ul>
          <li>業務システム開発：30万円〜</li>
          <li>保守・運用サポート：月1万円〜</li>
        </ul>
        <p>※規模・機能によって異なります。まずはご相談ください。</p>
      </div>
      <div class="cta-group">
        <a class="btn-primary" href="/contact">見積もりを相談する</a>
        <a class="btn-secondary" href="/cases">導入事例を見る</a>
      </div>
    </div>
  </section>

  <!-- 開発事例（8件） -->
  <section id="cases" class="section cases-section">
    <div class="section-inner">
      <h2 class="section-title">Excel運用を変えた導入事例</h2>
      <p style="margin: 0 0 24px; color: #555;">業種別の現場課題を解決した事例を紹介します。</p>
      <div class="cases-grid">
        <div class="case-card"><h3>引越業者</h3><p>案件管理システムによりExcel管理から脱却</p></div>
        <div class="case-card"><h3>訪問看護</h3><p>記録・勤務・お知らせを一元管理</p></div>
        <div class="case-card"><h3>EC・BUYMA</h3><p>商品分析・バイヤー分析を実装</p></div>
        <div class="case-card"><h3>製造業</h3><p>見積・工程・納品・請求を一元管理</p></div>
        <div class="case-card"><h3>福祉施設</h3><p>在庫管理のリアルタイム化</p></div>
        <div class="case-card"><h3>レンタカー</h3><p>発注・在庫・進捗を一元管理</p></div>
        <div class="case-card"><h3>入場管理</h3><p>QRコード入場管理を複数店舗対応</p></div>
        <div class="case-card"><h3>物流</h3><p>発注管理で大手企業の受発注業務を効率化</p></div>
      </div>
      <div class="cta-group">
        <a class="btn-primary" href="/contact">同じような課題で相談する</a>
        <a class="btn-secondary" href="/cases">事例をもっと見る</a>
      </div>
    </div>
  </section>

  <!-- ツール提供実績 -->
  <section id="tools" class="section tools-section">
    <div class="section-inner">
      <h2 class="section-title">ツール提供実績</h2>
      <ul class="tools-list">
        <li>楽天・Yahoo出品ツール：89社以上（取引件数378件以上）</li>
        <li>オンライン抽選システム：30件</li>
        <li>予約管理サイト：40件</li>
      </ul>
      <p class="tools-desc">
        現場の担当者視点で使いやすさを最優先に設計。<br />
        手動作業を減らし、精度・スピードを高める仕組みと、長期保守での安定化を両立します。
      </p>
      <div class="cta-group">
        <a class="btn-primary" href="/contact">ツール導入について相談する</a>
        <a class="btn-secondary" href="/cases">事例を見る</a>
      </div>
    </div>
  </section>

  <!-- よくある質問（5問） -->
  <section id="faq" class="section faq-section">
    <div class="section-inner">
      <h2 class="section-title">よくある質問</h2>
      <div class="faq-grid">
        <div class="faq-card">
          <h3>保守費用は必要ですか？</h3>
          <p>はい。システムは作って終わりではなく、継続的な改善と安定運用が重要です。月1万円〜の保守プランで安心を提供します。</p>
        </div>
        <div class="faq-card">
          <h3>開発期間はどれくらいですか？</h3>
          <p>規模にもよりますが、簡単な業務システムであれば約1〜2か月程度が目安です。要件によって調整します。</p>
        </div>
        <div class="faq-card">
          <h3>Excel管理からシステムに移行したい場合、まず何をすればいいですか？</h3>
          <p>まずは現状の運用と課題をヒアリングします。Excelの課題を整理したうえで、必要な機能を絞り込みます。</p>
        </div>
        <div class="faq-card">
          <h3>料金はいくらですか？</h3>
          <p>業務システム開発は30万円〜、保守は月1万円〜。機能・規模により変動しますので、まずはご相談ください。</p>
        </div>
        <div class="faq-card faq-full">
          <h3>相談だけでもできますか？</h3>
          <p>はい。まずはお気軽にご相談ください。文字ベースでのやり取りを基本としています。</p>
        </div>
      </div>
      <div class="cta-group">
        <a class="btn-primary" href="/contact">お問い合わせはこちら</a>
      </div>
    </div>
  </section>

  <!-- 最下部CTA -->
  <section id="contact-cta" class="section cta-section">
    <div class="section-inner">
      <div class="cta-block">
        <h2>まずは相談フォームから、現状と課題を教えてください</h2>
        <p>
          文字ベースでの相談が基本です。電話やZoomは不要です。<br />
          どんな相談でも構いません。現状の課題や業務の流れをお聞かせください。<br />
          送信後、1日以内に一次回答をお送りします。
        </p>
        <div class="cta-group" style="justify-content: center;">
          <a class="btn-primary" href="/contact">まずは相談する</a>
          <a class="btn-secondary" href="/cases">導入事例を見る</a>
        </div>
      </div>
    </div>
  </section>

</Layout>
