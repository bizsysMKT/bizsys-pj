---
import Layout from '../components/Layout.astro';
---

<Layout title="そのExcel管理、そろそろ限界じゃないですか？ | BizSys" description="Excelでの在庫・受注・日報管理に限界を感じている中小企業向けに、現場に合った業務システムを設計・開発・保守します。まずは無料でご相談ください。">

  <style is:global>
    .fs-36{font-size:36px;}
    /* ====================================================
       ヒーロー
       ==================================================== */
    .hero {
      background: #f3f8fd;
      padding: 40px 0;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      gap: 48px;
      align-items: center;
    }
    .hero h1 {
      font-size: 38px;
      line-height: 1.35;
      font-weight: 900;
      margin: 0 0 24px;
      color: #000;
    }
    .hero h1 span { color: #005bac; }
    .hero-copy p {
      font-size: 17px;
      font-weight: 700;
      margin-bottom: 32px;
      color: #10233f;
    }
    .hero-buttons { display: flex; gap: 20px; }

    /* ---- ヒーロービジュアル ---- */
    .hero-visual {
      display: flex;
      gap: 12px;
      align-items: center;
      justify-content: center;
      min-width: 0;
    }
    .hero-visual-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      flex-shrink: 1;
      min-width: 0;
    }
    .hero-badge {
      display: inline-block;
      background: #555;
      color: #fff;
      padding: 7px 16px;
      border-radius: 999px;
      font-size: 14px;
      font-weight: 700;
      white-space: nowrap;
    }
    .hero-badge.blue { background: #005bac; }
    .hero-visual img {
      height: 240px;
      width: auto;
      display: block;
      mix-blend-mode: multiply;
    }
    .hero-arrow {
      font-size: 48px;
      color: #005bac;
      font-weight: 900;
      text-align: center;
      line-height: 1;
      flex-shrink: 0;
    }

    /* ====================================================
       実績数字（豊富な実績で安心してお任せいただけます）
       ==================================================== */
    .results-section {
      padding: 35px 20px;
      background: #ffffff;
    }
    .results-container {
      max-width: 920px;
      margin: 0 auto;
    }
    .section-title-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 28px;
      margin-bottom: 38px;
    }
    .section-title-wrap h2 {
      margin: 0;
      color: #10243e;
      font-size: 28px;
      font-weight: 800;
      line-height: 1.35;
      letter-spacing: 0.06em;
      text-align: center;
    }
    .section-line {
      width: 86px;
      height: 2px;
      background: linear-gradient(90deg, transparent, #2368c4, transparent);
    }
    .results-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 18px;
      margin-bottom: 24px;
    }
    .result-card {
      position: relative;
      min-height: 248px;
      padding: 22px 16px 20px;
      background: #ffffff;
      border: 2px solid #d6e7f7;
      border-radius: 14px;
      box-shadow: 0 8px 22px rgba(31, 70, 112, 0.08);
      text-align: center;
    }
    .result-card--featured {
      border-color: #e5af32;
      box-shadow: 0 16px 42px rgba(199, 138, 0, 0.13);
    }
    .result-icon {
      height: 54px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .result-icon img {
      width: 54px;
      height: 54px;
      object-fit: contain;
    }
    .result-label {
      min-height: 48px;
      margin: 0 0 10px;
      color: #10243e;
      font-size: 17px;
      font-weight: 800;
      line-height: 1.35;
      letter-spacing: 0.04em;
    }
    .result-label sup {
      font-size: 11px;
      font-weight: 700;
      vertical-align: super;
    }
    .result-number {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 10px;
      margin-bottom: 18px;
    }
    .result-number span {
      display: inline-block;
      color: #2368c4;
      font-size: 40px;
      font-weight: 800;
      line-height: 0.92;
      letter-spacing: -0.04em;
    }
    .result-number strong {
      color: #2368c4;
      font-size: 16px;
      font-weight: 800;
      line-height: 1.2;
      text-align: left;
      white-space: nowrap;
    }
    .result-card--gold .result-number span,
    .result-card--gold .result-number strong {
      color: #c78a00;
    }
    .result-card--green .result-number span,
    .result-card--green .result-number strong {
      color: #5aac68;
    }
    .result-description {
      margin: 0;
      color: #17243a;
      font-size: 13.5px;
      line-height: 1.8;
      letter-spacing: 0.02em;
    }
    .result-link {
      display: inline-block;
      margin-top: 10px;
      color: #516071;
      font-size: 12px;
      text-decoration: underline;
    }
    .results-note {
      display: grid;
      grid-template-columns: 96px 1fr;
      gap: 22px;
      align-items: center;
      padding: 18px 22px;
      margin: 0 0 30px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px dashed #8eb8df;
      border-radius: 14px;
    }
    .note-badge {
      width: 66px;
      height: 66px;
      display: flex;
      align-items: center;
      justify-content: center;
      justify-self: center;
      border-radius: 50%;
      color: #ffffff;
      background: linear-gradient(135deg, #1558b4, #2372d1);
      font-size: 14px;
      font-weight: 800;
      line-height: 1.35;
      text-align: center;
    }
    .note-text p {
      margin: 0;
      color: #17243a;
      font-size: 13.5px;
      line-height: 1.8;
    }
    .team-message {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 24px;
      align-items: center;
      padding: 24px 28px;
      border-radius: 14px;
      background: linear-gradient(90deg, #eaf4ff 0%, #f8fcff 100%);
      box-shadow: 0 12px 30px rgba(31, 70, 112, 0.08);
    }
    .team-icon img {
      width: 66px;
      height: 66px;
      object-fit: contain;
    }
    .team-message h3 {
      margin: 0 0 8px;
      color: #2368c4;
      font-size: 18px;
      font-weight: 800;
      letter-spacing: 0.04em;
    }
    .team-message p {
      margin: 0;
      color: #17243a;
      font-size: 13.5px;
      line-height: 1.85;
    }

    /* ====================================================
       課題グリッド / 理由グリッド
       ==================================================== */
    .problem-heading {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .problem-heading-icon {
      width: 32px;
      height: auto;
    }
    .problem-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 14px;
    }
    .problem-card {
      background: #fff;
      border: 1px solid #dce8f4;
      border-radius: 10px;
      padding: 18px 16px;
      box-shadow: 0 4px 12px rgba(18, 65, 110, .05);
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    .problem-icon {
      width: 48px;
      height: auto;
      flex-shrink: 0;
      mix-blend-mode: multiply;
    }
    .problem-title {
      font-size: 15px;
      font-weight: 800;
      color: #073b78;
      margin: 0 0 4px;
    }
    .problem-desc {
      font-size: 15px;
      font-weight: bold;
      margin: 0;
      line-height: 1.5;
    }
    .reason-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
    .reason-card {
      background: #fff;
      border: 1px solid #dce8f4;
      border-radius: 10px;
      padding: 20px 18px;
      box-shadow: 0 4px 12px rgba(18, 65, 110, .05);
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }
    .reason-icon {
      width: 52px;
      height: 52px;
      object-fit: contain;
      flex-shrink: 0;
    }
    .reason-title {
      font-size: 15px;
      font-weight: 800;
      color: #073b78;
      margin: 0 0 6px;
    }
    .reason-desc {
      font-size: 15px;
      color: #555;
      margin: 0;
      line-height: 1.6;
    }

    /* ====================================================
       2カラム（コスト / 解決策）
       ==================================================== */
    .two-column {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .panel-lead { color: #555; margin: 0 0 4px; }

    /* ---- コストフロー ---- */
    .cost-flow {
      display: grid;
      grid-template-columns: 1fr 28px 1fr 28px 1fr;
      align-items: center;
      gap: 8px;
      margin: 20px 0 12px;
    }
    .cost-box {
      background: #f6f9fc;
      border: 1px solid #dce8f4;
      border-radius: 10px;
      padding: 16px 12px;
      text-align: center;
      font-weight: 800;
      font-size: 15px;
      line-height: 1.6;
    }
    .cost-box--highlight {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
    }
    .cost-label { font-size: 14px; font-weight: 700; color: #777; }
    .cost-amount { color: #ff7a00; font-weight: 900; line-height: 1.1; white-space: nowrap; }
    .cost-sub { font-size: 14px; font-weight: 400; color: #888; }
    .cost-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .cost-arrow::after {
      content: '';
      display: block;
      width: 0;
      height: 0;
      border-top: 9px solid transparent;
      border-bottom: 9px solid transparent;
      border-left: 14px solid #005bac;
    }
    .note { font-size: 14px; color: #252525; margin: 0; }

    /* ---- ROIバナー ---- */
    .roi-banner {
      margin-top: 16px;
      background: linear-gradient(135deg, #003070, #004faa);
      border-radius: 14px;
      padding: 20px 24px;
      color: #fff;
    }
    .roi-banner__lead {
      font-size: 13px;
      font-weight: 700;
      opacity: 0.8;
      margin-bottom: 10px;
      letter-spacing: 0.04em;
    }
    .roi-banner__body {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
    }
    .roi-banner__calc {
      font-size: 16px;
      font-weight: 800;
      background: rgba(255,255,255,0.12);
      border-radius: 8px;
      padding: 6px 14px;
      white-space: nowrap;
    }
    .roi-banner__eq {
      font-size: 22px;
      font-weight: 900;
      opacity: 0.6;
    }
    .roi-banner__result {
      font-size: 16px;
      font-weight: 700;
    }
    .roi-banner__result strong {
      font-size: 34px;
      font-weight: 900;
      color: #ffd04a;
      margin: 0 4px;
      line-height: 1;
    }
    .roi-banner__note {
      margin-top: 12px;
      font-size: 13px;
      font-weight: 700;
      opacity: 0.75;
      border-top: 1px solid rgba(255,255,255,0.2);
      padding-top: 10px;
    }

    /* ---- 解決策グリッド ---- */
    .solution-tagline { font-size: 14px; color: #5a6b86; font-weight: 700; margin: -8px 0 14px; }
    .solution-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
    .solution-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      background: #fff;
      border: 1px solid #dce8f4;
      border-radius: 14px;
      padding: 14px 16px;
      box-shadow: 0 2px 8px rgba(18,65,110,.05);
    }
    .solution-card__left { display: flex; align-items: center; gap: 14px; min-width: 0; }
    .solution-card__icon {
      width: 68px; height: 68px;
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .solution-card__icon img { width: 60px; height: 60px; object-fit: contain; }
    .solution-card__icon.blue  { background: #e8f0fe; }
    .solution-card__icon.orange{ background: #fff1e0; }
    .solution-card__icon.green { background: #e4f7ef; }
    .solution-card__name { font-size: 16px; font-weight: 900; color: #0d2b50; margin: 0 0 3px; }
    .solution-card__desc { font-size: 13px; color: #5a6b86; font-weight: 700; margin: 0; }
    .solution-card__right {
      display: flex; align-items: center; gap: 8px;
      flex-shrink: 0; white-space: nowrap;
    }
    .stag {
      font-size: 12px; font-weight: 800;
      padding: 4px 10px; border-radius: 999px;
    }
    .stag.before { background: #f0f3f7; color: #8a9ab5; }
    .stag.after-blue   { background: #deeaff; color: #1a56c4; }
    .stag.after-orange { background: #ffe9cc; color: #c45c00; }
    .stag.after-green  { background: #cdf2e2; color: #0b7a52; }
    .solution-arrow { color: #b0bec9; font-size: 16px; font-weight: 900; }
    .solution-footer {
      margin-top: 14px;
      background: linear-gradient(135deg, #003070, #004faa);
      color: #fff;
      border-radius: 12px;
      padding: 14px 18px;
      font-size: 14px;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .solution-footer-check {
      width: 22px; height: 22px;
      background: rgba(255,255,255,0.18);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px;
      flex-shrink: 0;
    }
    .sf-l1, .sf-l2, .sf-l3 { display: inline; }
    .solution-footer mark {
      background: none;
      font-weight: 900;
    }
    .solution-footer mark.c-blue   { color: #7ec8f0; }
    .solution-footer mark.c-orange { color: #ffb866; }
    .solution-footer mark.c-green  { color: #6be0af; }

    /* ====================================================
       導入事例
       ==================================================== */
    .case-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
    .case-card {
      background: #fff;
      border: 1px solid #dce8f4;
      border-radius: 10px;
      padding: 18px;
      box-shadow: 0 4px 12px rgba(18, 65, 110, .05);
    }
    .case-badge {
      display: inline-block;
      background: #d9ecfb;
      color: #073b78;
      font-size: 14px;
      font-weight: 800;
      padding: 4px 10px;
      border-radius: 6px;
      margin-bottom: 12px;
    }
    .case-body {
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }
    .case-img {
      width: 72px;
      height: 72px;
      object-fit: contain;
      flex-shrink: 0;
      mix-blend-mode: multiply;
    }
    .case-text { flex: 1; min-width: 0; }
    .case-card h3 {
      font-size: 15px;
      font-weight: 800;
      color: #073b78;
      margin: 0 0 6px;
    }
    .case-card p {
      font-size: 15px;
      color: #555;
      margin: 0 0 8px;
      line-height: 1.6;
    }
    .case-metric {
      display: block;
      color: #ff7a00;
      font-size: 15px;
      font-weight: 700;
    }
    .case-metric strong {
      font-size: 16px;
      font-weight: 900;
    }
    .case-more {
      text-align: center;
      margin-top: 28px;
    }
    .case-more a {
      color: #005bac;
      font-weight: 700;
      font-size: 15px;
    }
    .case-more a:hover { text-decoration: underline; }

    /* ====================================================
       料金
       ==================================================== */
    .price-section {
      background: #fafbfc;
      padding: 48px 0;
    }
    .price-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }
    .price-card {
      min-height: 200px;
      border-radius: 9px;
      padding: 28px 38px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      overflow: hidden;
    }
    .price-card.blue  { background: linear-gradient(90deg, #edf7ff, #f9fcff); }
    .price-card.green { background: linear-gradient(90deg, #f0fbf3, #f9fff8); }
    .price-card h3 {
      color: #0a4a99;
      font-size: 22px;
      font-weight: 800;
      margin: 0;
    }
    .price-card.green h3 { color: #2a7b43; }
    .price-card .price {
      font-size: 34px;
      color: #0a4a99;
      margin: 4px 0;
      font-weight: 800;
      white-space: nowrap;
    }
    .price-card.green .price { color: #2a7b43; }
    .price-card .price strong {
      font-size: 58px;
      line-height: 1;
      font-weight: 900;
    }
    .price-card small {
      display: block;
      color: #444;
      margin-bottom: 10px;
      font-size: 14px;
    }
    .price-card p:last-of-type { font-size: 15px; margin: 0; }
    .price-card .price-img {
      max-width: 185px;
      opacity: .85;
      flex-shrink: 0;
    }
    .price-card .shield {
      max-width: 190px;
      opacity: .42;
      transform: translate(20px, 4px);
      flex-shrink: 0;
    }
    .price-footnote {
      text-align: center;
      color: #244668;
      font-size: 14px;
      margin: 12px 0 0;
    }

    /* ====================================================
       下部CTA
       ==================================================== */
    .cta {
      background: #003f82;
      color: #fff;
      padding: 56px 0;
    }
    .cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 40px;
    }
    .cta h2 { color: #fff; font-size: 32px; margin-bottom: 8px; }
    .cta p { color: rgba(255,255,255,0.85); margin: 0; font-size: 16px; }
    .cta-points {
      display: flex;
      gap: 28px;
      margin-top: 20px;
      font-weight: 700;
      font-size: 14px;
      color: rgba(255,255,255,0.8);
      flex-wrap: wrap;
    }

    /* ====================================================
       レスポンシブ
       ==================================================== */
    @media (max-width: 960px) {
      .results-grid {
        grid-template-columns: 1fr;
        gap: 22px;
      }
      .result-card { min-height: auto; }
      .result-label { min-height: auto; }
      .section-title-wrap { gap: 16px; }
      .section-line { width: 42px; }
    }
    @media (max-width: 640px) {
      .results-section { padding: 48px 16px; }
      .section-title-wrap {
        display: block;
        margin-bottom: 28px;
      }
      .section-line { display: none; }
      .section-title-wrap h2 {
        font-size: 22px;
        text-align: center;
      }
      .result-card { padding: 22px 16px; }
      .result-label { font-size: 17px; }
      .result-number span { font-size: 40px; }
      .result-number strong { font-size: 16px; }
      .results-note,
      .team-message {
        grid-template-columns: 1fr;
        gap: 16px;
        padding: 22px 18px;
      }
      .note-badge {
        justify-self: start;
        width: auto;
        height: auto;
        padding: 8px 14px;
        border-radius: 999px;
      }
      .team-message h3 { font-size: 18px; }
      .results-section .pc-only { display: none; }
    }
    @media (max-width: 900px) {
      .hero-inner,
      .two-column,
      .price-grid { grid-template-columns: 1fr; }
      .hero h1 { font-size: 34px; }
      .hero-visual {
        flex-direction: column;
        gap: 16px;
      }
      .hero-visual img {
        height: auto;
        width: min(340px, 100%);
      }
      .hero-arrow { transform: rotate(90deg); }
      .reason-grid,
      .case-grid { grid-template-columns: 1fr 1fr; }
      .problem-grid { grid-template-columns: 1fr 1fr; }
      .cta-inner { flex-direction: column; align-items: flex-start; }
    }
    @media (max-width: 560px) {
      .hero h1 { font-size: 28px; }
      .hero-buttons { flex-direction: column; }
      .problem-grid,
      .reason-grid,
      .case-grid,
      .solution-grid { grid-template-columns: 1fr; }
      .cost-flow { grid-template-columns: 1fr; }
      .price-card .price-img { display: none; }
      .cost-flow span { text-align: center; }
      .cost-arrow::after {
        border-top: 14px solid #005bac;
        border-bottom: none;
        border-left: 9px solid transparent;
        border-right: 9px solid transparent;
      }
      .cta-points { flex-direction: column; gap: 8px; }
      /* solutionカードをスマホで縦積みにしてタグのはみ出しを防ぐ */
      .solution-card { flex-direction: column; align-items: flex-start; gap: 10px; }
      .solution-card__right { white-space: normal; flex-shrink: 1; }
      /* ROIバナー：calc＋eqを1行、resultを次の行に */
      .roi-banner { padding: 20px 10px; }
      .roi-banner__body { flex-direction: row; flex-wrap: wrap; align-items: center; gap: 8px; }
      .roi-banner__result { width: 100%; }
      /* solution-footer を3行表示 */
      .sf-text { display: flex; flex-direction: column; gap: 2px; }
      .sf-l1, .sf-l2, .sf-l3 { display: block; }
      .solution-footer { padding: 8px 10px; gap: 6px; }
    }
  </style>

  <!--/* ヒーロー */-->
  <section class="hero pb-5 pt-5">
    <div class="container hero-inner pb-4">
      <div class="hero-copy">
        <h1>
          そのExcel管理、<br>
          そろそろ<span>限界</span>じゃないですか？
        </h1>
        <p style="font-size:17px;">
          入力ミス、集計作業、属人化…<br>
          現場の業務を整理し、使いやすいシステムに置き換えます。
        </p>
